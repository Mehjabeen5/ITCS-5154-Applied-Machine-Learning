# 3. DATA PREPROCESSING
# ============================================================================

def preprocess_data(train, test):
    """Preprocess training and test data"""
    print("\n" + "="*70)
    print("STEP 3: DATA PREPROCESSING")
    print("="*70)
    
    # Find target column
    target_col = 'SalePrice' if 'SalePrice' in train.columns else None
    if target_col is None:
        price_cols = [col for col in train.columns if 'price' in col.lower()]
        if price_cols:
            target_col = price_cols[0]
    
    # Store target variable and IDs
    if target_col and target_col in train.columns:
        y_train = train[target_col].copy()
    else:
        raise ValueError("Target column 'SalePrice' not found!")
    
    # Check for ID columns
    id_cols = [col for col in train.columns if col.lower() in ['id', 'order', 'pid']]
    
    # Store IDs if they exist
    train_id = train[id_cols[0]].copy() if id_cols else train.index.copy()
    test_id = test[id_cols[0]].copy() if id_cols else test.index.copy()
    
    # Drop ID columns and target from features
    cols_to_drop = id_cols + ([target_col] if target_col in train.columns else [])
    train_features = train.drop(cols_to_drop, axis=1, errors='ignore')
    test_features = test.drop(cols_to_drop, axis=1, errors='ignore')
    
    # Combine train and test for consistent preprocessing
    n_train = train_features.shape[0]
    all_data = pd.concat([train_features, test_features], axis=0, ignore_index=True)
    
    print(f"Combined data shape: {all_data.shape}")
    print(f"Features: {all_data.shape[1]}")
    
    # 3.1 Handle missing values
    print("\n3.1 Handling Missing Values")
    
    # Features where NA means 'None' or 'Not Applicable'
    none_features = ['PoolQC', 'MiscFeature', 'Alley', 'Fence', 'FireplaceQu',
                     'GarageType', 'Garage Finish', 'Garage Qual', 'Garage Cond',
                     'BsmtQual', 'Bsmt Cond', 'Bsmt Exposure', 'BsmtFin Type 1', 'BsmtFin Type 2',
                     'Mas Vnr Type']
    
    for col in none_features:
        if col in all_data.columns:
            all_data[col].fillna('None', inplace=True)
    
    # Fill numerical features with median
    numerical_features = all_data.select_dtypes(include=[np.number]).columns
    for col in numerical_features:
        if all_data[col].isnull().sum() > 0:
            all_data[col].fillna(all_data[col].median(), inplace=True)
    
    # Fill categorical features with mode
    categorical_features = all_data.select_dtypes(include=['object']).columns
    for col in categorical_features:
        if all_data[col].isnull().sum() > 0:
            all_data[col].fillna(all_data[col].mode()[0], inplace=True)
    
    print(f"Missing values after preprocessing: {all_data.isnull().sum().sum()}")
    
    # 3.2 Log transform target variable
    print("\n3.2 Log Transforming Target Variable")
    y_train_log = np.log1p(y_train)
    print(f"Original skewness: {y_train.skew():.2f}")
    print(f"Log-transformed skewness: {y_train_log.skew():.2f}")
    
    return all_data, y_train_log, n_train, train_id, test_id


