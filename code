def main():
    """Main execution function"""
    print("\n" + "="*70)
    print("MAIN EXECUTION - AMES HOUSING PREDICTION")
    print("="*70)
    
    # Step 1: Load data
    train, test = load_data()
    
    # Step 2: EDA
    correlations = perform_eda(train)
    
    # Step 3: Preprocess
    all_data, y_train_log, n_train, train_id, test_id = preprocess_data(train, test)
    
    # Step 4: Feature engineering
    all_data = engineer_features(all_data)
    
    # Step 5: Split back into train and test
    X_train_full = all_data[:n_train]
    X_test = all_data[n_train:]
    
    print(f"\nFinal shapes:")
    print(f"X_train: {X_train_full.shape}")
    print(f"X_test: {X_test.shape}")
    
    # Step 6: Create validation split
    X_train, X_val, y_train, y_val = train_test_split(
        X_train_full, y_train_log, test_size=0.2, random_state=42
    )
    
    # Step 7: Train models
    results = train_models(X_train, y_train, X_val, y_val)
    
    # Step 8: Compare models
    comparison = compare_models(results)
    
    # Step 9: Use best model for final predictions
    best_model_name = comparison.iloc[0]['Model']
    best_model = results[best_model_name]['model']
    
    print(f"\n✓ Best model: {best_model_name}")
    
    # Retrain on full training data
    print(f"\nRetraining {best_model_name} on full training data...")
    best_model.fit(X_train_full, y_train_log)
    
    # Make predictions
    submission = make_predictions(best_model, X_test, test_id)
    
    print("\n" + "="*70)
    print("✓ EXECUTION COMPLETED SUCCESSFULLY!")
    print("="*70)
    print("\nCheck outputs/figures/ for visualizations")
    print("Check outputs/submission.csv for predictions")
    
    return results, comparison, submission


if __name__ == "__main__":
    results, comparison, submission = main()
