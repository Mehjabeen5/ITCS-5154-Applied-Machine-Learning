# 4. FEATURE ENGINEERING
# ============================================================================

def engineer_features(all_data):
    """Create new features and transform existing ones"""
    print("\n" + "="*70)
    print("STEP 4: FEATURE ENGINEERING")
    print("="*70)
    
    print("\n4.1 Creating New Features")
    
    # Helper function to find column (handles spaces)
    def find_col(pattern):
        matches = [col for col in all_data.columns if pattern.lower() in col.lower().replace(' ', '')]
        return matches[0] if matches else None
    
    # Total square footage (be flexible with column names)
    basement_col = find_col('totalbsmtsf') or find_col('bsmtsf')
    first_floor = find_col('1stflrsf') or find_col('firstfloor')
    second_floor = find_col('2ndflrsf') or find_col('secondfloor')
    
    if basement_col and first_floor and second_floor:
        all_data['TotalSF'] = (all_data[basement_col] + 
                               all_data[first_floor] + 
                               all_data[second_floor])
        print("✓ Created TotalSF")
    
    # Total bathrooms
    full_bath = find_col('fullbath')
    bsmt_full = find_col('bsmtfullbath')
    half_bath = find_col('halfbath')
    bsmt_half = find_col('bsmthalfbath')
    
    if all([full_bath, bsmt_full, half_bath, bsmt_half]):
        all_data['TotalBathrooms'] = (all_data[full_bath] + 
                                      all_data[bsmt_full] + 
                                      0.5 * all_data[half_bath] + 
                                      0.5 * all_data[bsmt_half])
        print("✓ Created TotalBathrooms")
    
    # House age
    yr_sold = find_col('yrsold')
    yr_built = find_col('yearbuilt')
    if yr_sold and yr_built:
        all_data['HouseAge'] = all_data[yr_sold] - all_data[yr_built]
        print("✓ Created HouseAge")
    
    # Remodel flag
    yr_remod = find_col('yearremodadd')
    if yr_built and yr_remod:
        all_data['Remodeled'] = (all_data[yr_remod] != all_data[yr_built]).astype(int)
        print("✓ Created Remodeled flag")
    
    # Total porch area
    porch_cols = [find_col(p) for p in ['openporch', 'enclosedporch', '3ssnporch', 'screenporch']]
    porch_cols = [c for c in porch_cols if c]
    if porch_cols:
        all_data['TotalPorchSF'] = all_data[porch_cols].sum(axis=1)
        print("✓ Created TotalPorchSF")
    
    # Has pool
    pool_col = find_col('poolarea')
    if pool_col:
        all_data['HasPool'] = (all_data[pool_col] > 0).astype(int)
        print("✓ Created HasPool")
    
    # Has garage
    garage_col = find_col('garagearea')
    if garage_col:
        all_data['HasGarage'] = (all_data[garage_col] > 0).astype(int)
        print("✓ Created HasGarage")
    
    # Has basement
    if basement_col:
        all_data['HasBsmt'] = (all_data[basement_col] > 0).astype(int)
        print("✓ Created HasBsmt")
    
    print(f"\nTotal features now: {all_data.shape[1]}")
    
    # 4.2 Handle skewed features
    print("\n4.2 Handling Skewed Features")
    numeric_feats = all_data.dtypes[all_data.dtypes != "object"].index
    
    # Check skewness
    skewed_feats = all_data[numeric_feats].apply(lambda x: skew(x.dropna())).sort_values(ascending=False)
    skewness = pd.DataFrame({'Skew': skewed_feats})
    
    # Transform highly skewed features (skewness > 0.75)
    skewed_features = skewness[abs(skewness['Skew']) > 0.75].index
    print(f"Found {len(skewed_features)} highly skewed features")
    
    for feat in skewed_features:
        all_data[feat] = np.log1p(all_data[feat])
    
    # 4.3 Encode categorical variables
    print("\n4.3 Encoding Categorical Variables")
    categorical_features = all_data.select_dtypes(include=['object']).columns
    print(f"Encoding {len(categorical_features)} categorical features")
    
    # One-hot encoding for all categorical features
    all_data = pd.get_dummies(all_data, drop_first=True)
    
    print(f"Final feature count after encoding: {all_data.shape[1]}")
    
    return all_data


