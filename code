def train_models(X_train, y_train, X_val, y_val):
    """Train multiple models as per Sharma et al. (2024)"""
    print("\n" + "="*70)
    print("STEP 5: MODEL TRAINING")
    print("="*70)
    
    results = {}
    
    # 5.1 Linear Regression (Baseline)
    print("\n5.1 Training Linear Regression (Baseline)")
    lr = LinearRegression()
    lr.fit(X_train, y_train)
    y_pred_lr = lr.predict(X_val)
    rmse_lr = np.sqrt(mean_squared_error(y_val, y_pred_lr))
    r2_lr = r2_score(y_val, y_pred_lr)
    results['Linear Regression'] = {'RMSE': rmse_lr, 'R2': r2_lr, 'model': lr}
    print(f"Linear Regression - RMSE: {rmse_lr:.5f}, R²: {r2_lr:.5f}")
    
    # 5.2 Random Forest
    print("\n5.2 Training Random Forest")
    rf = RandomForestRegressor(n_estimators=100, random_state=42, n_jobs=-1)
    rf.fit(X_train, y_train)
    y_pred_rf = rf.predict(X_val)
    rmse_rf = np.sqrt(mean_squared_error(y_val, y_pred_rf))
    r2_rf = r2_score(y_val, y_pred_rf)
    results['Random Forest'] = {'RMSE': rmse_rf, 'R2': r2_rf, 'model': rf}
    print(f"Random Forest - RMSE: {rmse_rf:.5f}, R²: {r2_rf:.5f}")
    
    # 5.3 XGBoost (Primary Model)
    print("\n5.3 Training XGBoost")
    xgb_model = xgb.XGBRegressor(
        n_estimators=1000,
        learning_rate=0.05,
        max_depth=3,
        random_state=42,
        n_jobs=-1
    )
    xgb_model.fit(X_train, y_train)
    y_pred_xgb = xgb_model.predict(X_val)
    rmse_xgb = np.sqrt(mean_squared_error(y_val, y_pred_xgb))
    r2_xgb = r2_score(y_val, y_pred_xgb)
    results['XGBoost'] = {'RMSE': rmse_xgb, 'R2': r2_xgb, 'model': xgb_model}
    print(f"XGBoost - RMSE: {rmse_xgb:.5f}, R²: {r2_xgb:.5f}")
    
    return results


def compare_models(results):
    """Compare all models"""
    print("\n" + "="*70)
    print("MODEL COMPARISON")
    print("="*70)
    
    comparison_df = pd.DataFrame({
        'Model': list(results.keys()),
        'RMSE': [results[m]['RMSE'] for m in results.keys()],
        'R²': [results[m]['R2'] for m in results.keys()]
    }).sort_values('RMSE')
    
    print("\n" + comparison_df.to_string(index=False))
    
    # Visualize
    fig, axes = plt.subplots(1, 2, figsize=(14, 5))
    
    axes[0].barh(comparison_df['Model'], comparison_df['RMSE'])
    axes[0].set_xlabel('RMSE (lower is better)')
    axes[0].set_title('Model Comparison - RMSE')
    axes[0].invert_yaxis()
    
    axes[1].barh(comparison_df['Model'], comparison_df['R²'])
    axes[1].set_xlabel('R² Score (higher is better)')
    axes[1].set_title('Model Comparison - R²')
    axes[1].invert_yaxis()
    
    plt.tight_layout()
    plt.savefig('outputs/figures/model_comparison.png', dpi=300, bbox_inches='tight')
    plt.show()
    
    return comparison_df


def make_predictions(model, X_test, test_id):
    """Make predictions on test set"""
    print("\n" + "="*70)
    print("MAKING PREDICTIONS ON TEST SET")
    print("="*70)
    
    y_pred_log = model.predict(X_test)
    y_pred = np.expm1(y_pred_log)
    
    submission = pd.DataFrame({
        'Id': test_id,
        'SalePrice': y_pred
    })
    
    submission.to_csv('outputs/submission.csv', index=False)
    print("\n✓ Submission file created: outputs/submission.csv")
    print(f"Predictions: {len(submission)} houses")
    print(f"\nSample predictions:")
    print(submission.head(10))
    
    return submission


